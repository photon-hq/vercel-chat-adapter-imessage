{
  "name": "chat-adapter-imessage",
  "version": "0.1.1",
  "description": "iMessage adapter for Chat SDK",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage",
    "test:peers": "bash scripts/test-peer-deps.sh"
  },
  "peerDependencies": {
    "chat": "^4.14.0"
  },
  "dependencies": {
    "@chat-adapter/shared": "^4.15.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.57.2",
    "@photon-ai/advanced-imessage-kit": "^1.14.3",
    "@photon-ai/imessage-kit": "^2.1.2"
  },
  "devDependencies": {
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-metrics": "^2.6.0",
    "@opentelemetry/sdk-trace-node": "^2.6.0",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^4.0.18",
    "chat": "^4.15.0",
    "tsup": "^8.3.5",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.30.3",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "chat-sdk",
    "chat-adapter",
    "imessage",
    "sms",
    "bot",
    "adapter"
  ],
  "author": "photon",
  "repository": {
    "type": "git",
    "url": "https://github.com/photon-hq/vercel-chat-adapter-imessage.git"
  },
  "homepage": "https://github.com/photon-hq/vercel-chat-adapter-imessage",
  "bugs": {
    "url": "https://github.com/photon-hq/vercel-chat-adapter-imessage/issues"
  },
  "license": "MIT"
}
